    "todomvc-app-css": "^2.0.0"
  },
  "devDependencies": {
    "@storybook/addon-webpack5-compiler-babel": "^3.0.3",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9"
  }
}
